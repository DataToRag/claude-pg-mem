{
  "name": "claude-pg-mem",
  "version": "0.1.0",
  "description": "Postgres-native persistent memory for Claude Code — shared across instances and machines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-pg-mem": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "files": [
    "dist",
    "plugin"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "worker:start": "tsx src/index.ts",
    "worker:dev": "tsx watch src/index.ts",
    "test": "node --test",
    "lint": "tsc --noEmit",
    "build:plugin": "node scripts/build-plugin.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "postgres",
    "pgvector",
    "neon",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.40.0",
    "express": "^4.18.2",
    "glob": "^11.0.3",
    "pgvector": "^0.2.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.27.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
