# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Worker service port (default: 37778)
CLAUDE_PG_MEMORY_PORT=37778

# Data directory for settings and logs (default: ~/.claude-pg-memory)
CLAUDE_PG_MEMORY_DATA_DIR=~/.claude-pg-memory

# Embeddings run locally via Nomic Embed Text v1 — no API key needed
